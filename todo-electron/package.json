{
  "name": "todo-electron",
  "version": "1.0.0",
  "type": "module",
  "description": "Apple-style Todo App built with Electron + React + Vite",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "vite": "^4.4.5",
    "wait-on": "^7.0.1"
  },
  "build": {
  "appId": "com.todo.app",
  "productName": "Reminders",

  "extraMetadata": {
  "type": "module",
  "main": "electron/main.cjs"
  },

  "directories": {
    "output": "dist-electron"
  },

  "files": [
    "dist/**/*",
    "electron/**/*"
  ],

  "asar": true,

  "asarUnpack": [
    "electron/preload.js"
  ],

  "mac": { "category": "public.app-category.productivity" },
  "win": { "target": "nsis" },
  "linux": { "target": "AppImage" }
}
}
